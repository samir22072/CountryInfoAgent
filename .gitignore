# pyenv
#   For a library or binary, you wish to ignore these files periodically
#   to ensure you are using the correct version of python.
# .python-version

# pipenv
#   According to pypa/pipenv#1173, pipenv managed virtual environments are
#   stored outside the project directory.
#   However, if you are using 'PIPENV_VENV_IN_PROJECT=1', your venv will be
#   created in the project directory, which should be ignored.
# .venv

# poetry
#   Similar to pipenv, poetry managed virtual environments are usually
#   stored outside the project directory.
#   However, if you have set 'virtualenvs.in-project' to true, your venv will
#   be created in the project directory, which should be ignored.
# .venv

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

